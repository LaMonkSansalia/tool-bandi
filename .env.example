# Tool Bandi — Environment Variables
# Copy to .env and fill in values. Never commit .env!

# === Database ===
DATABASE_URL=postgresql://bandi:CHANGE_ME@db:5432/bandi_db
DB_NAME=bandi_db
DB_USER=bandi
DB_PASSWORD=CHANGE_ME

# === Web Auth (simple single-user) ===
AUTH_USER=luciano
AUTH_PASS=CHANGE_ME
SESSION_SECRET=CHANGE_ME_RANDOM_STRING

# === Claude API ===
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME

# === Redis (optional) ===
REDIS_URL=redis://localhost:6379/0

# === Eligibility thresholds ===
SCORE_NOTIFICATION_THRESHOLD=60
URGENCY_THRESHOLD_DAYS=14
ARCHIVE_AFTER_DAYS=3
